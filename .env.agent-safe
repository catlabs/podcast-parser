# .env.agent-safe
# ===============
# Non-sensitive project defaults. The application LOADS this file at startup
# (after .env), so values here actually drive behaviour. Precedence in
# rag/config.py is:  shell env > .env > .env.agent-safe.
#
# Rules:
# - Anything here must be NON-SENSITIVE: no API keys, no customer resource
#   names, no internal hostnames. AI agents and indexers may read this file.
# - Secrets and per-developer overrides go in .env (gitignored). Anything
#   you put in .env wins over what's here.
# - This file IS committed to git, so values here become the project
#   default for every developer / deployment on this branch.

# Local providers
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Local paths (relative to repo root)
OUTPUT_DIR=./output
DATA_DIR=./rag/data
CHROMA_DIR=./rag/data/chroma
DB_PATH=./rag/data/metadata.db

# FastAPI / Vite dev defaults
CORS_ALLOW_ORIGINS=http://localhost:5173
# VITE_API_BASE_URL=http://localhost:8000     # frontend uses this

# Azure: non-sensitive knobs ONLY. The endpoint URL and API key stay in .env
# because they identify (and authenticate to) the customer's Azure resource.
# Deployment names live here because they are generic model identifiers —
# move them back to .env if you ever rename to something project-specific
# like "acme-prod-rag-2026".
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.2-chat
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_COLLECTION=podcasts_azure

# Azure Blob Storage (Step 8b) — opt-in. Uncomment BOTH to route
# transcripts/audio to a blob container instead of the local OUTPUT_DIR.
# Auth uses DefaultAzureCredential (Managed Identity in Azure → `az login`
# locally → env baseline). No connection strings, no account keys belong
# in any .env file — those are credentials.
# AZURE_STORAGE_ACCOUNT=mystorageacct
# AZURE_STORAGE_CONTAINER=podcast-transcripts

# UI defaults shown in the toolbar (safe — these are just registry keys).
# UI_DEFAULT_EMBED_KEY="azure-openai" points at text-embedding-3-large via
# the Azure OpenAI deployment above. The key only resolves when the Azure
# embed entry is registered (AZURE_OPENAI_ENDPOINT + AZURE_OPENAI_EMBEDDING_DEPLOYMENT
# both set in .env); otherwise rag/config.py silently falls back to
# DEFAULT_MODEL_KEY ("minilm"), so local-only setups still work.
UI_DEFAULT_EMBED_KEY=azure-openai
UI_DEFAULT_LLM_KEY=azure-openai

# Langfuse: only the public host and the on/off knob are safe here.
# The public/secret keys are credentials and must live in .env only.
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=true
# Flip to true to include the full system+user prompt in the
# `final-generation` span input. Off by default to keep retrieved chunk
# text out of traces; the auto SDK observation under each generation
# still carries the raw message array if you need the unredacted view.
LANGFUSE_LOG_FULL_PROMPTS=false
# Default trace-level user_id when the HTTP request body omits one (e.g.
# direct curl, or before the UI has settled a localStorage user_id).
# The UI always sends a per-browser UUID; this fallback is mostly for CLI
# smoke tests and machine-to-machine calls.
LANGFUSE_DEFAULT_USER_ID=local-user

# LLM streaming toggle — flip to false to force non-streaming completions
# so Langfuse/OTel captures usage/token data reliably. Behaviour is
# identical from the caller's perspective; only the upstream SDK call
# shape changes.
ENABLE_LLM_STREAMING=false

# Pure-OTel side track (warm-up step A). When true, rag/otel.py builds a
# private TracerProvider and exports gen_ai.* spans through OTLP HTTP to
# Langfuse's OTel endpoint (LANGFUSE_HOST/api/public/otel/v1/traces),
# authenticating with Basic auth derived from LANGFUSE_PUBLIC_KEY/SECRET_KEY
# (those stay in .env). Off by default — the Langfuse SDK pipeline keeps
# running either way.
OTEL_ENABLED=true

# Application Insights / Azure Monitor — Phase 1.OBS.1
# Opt-in SECOND OTel exporter alongside Langfuse. When set, rag/otel.py
# attaches an AzureMonitorTraceExporter as a second BatchSpanProcessor on
# the same shared TracerProvider — identical spans fan out to Langfuse
# AND Application Insights. Auth is DefaultAzureCredential (Managed
# Identity in Azure → `az login` locally → env baseline). The
# InstrumentationKey embedded in the value is used for endpoint discovery
# only, NOT for authentication; the connection string itself is a
# workspace identifier (non-sensitive) but this committed file does NOT
# pin a developer's specific resource — fill in `.env` for opt-in.
# Shape (paste verbatim from the resource's Overview tab):
#   InstrumentationKey=<guid>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/;LiveEndpoint=https://<region>.livediagnostics.monitor.azure.com/
APPLICATIONINSIGHTS_CONNECTION_STRING=
