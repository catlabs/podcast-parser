# .env.agent-safe
# ===============
# Non-sensitive project defaults. The application LOADS this file at startup
# (after .env), so values here actually drive behaviour. Precedence in
# rag/config.py is:  shell env > .env > .env.agent-safe.
#
# Rules:
# - Anything here must be NON-SENSITIVE: no API keys, no customer resource
#   names, no internal hostnames. AI agents and indexers may read this file.
# - Secrets and per-developer overrides go in .env (gitignored). Anything
#   you put in .env wins over what's here.
# - This file IS committed to git, so values here become the project
#   default for every developer / deployment on this branch.

# Local providers
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Local paths (relative to repo root)
OUTPUT_DIR=./output
DATA_DIR=./rag/data
CHROMA_DIR=./rag/data/chroma
DB_PATH=./rag/data/metadata.db

# FastAPI / Vite dev defaults
CORS_ALLOW_ORIGINS=http://localhost:5173
# VITE_API_BASE_URL=http://localhost:8000     # frontend uses this

# Azure: non-sensitive knobs ONLY. The endpoint URL and API key stay in .env
# because they identify (and authenticate to) the customer's Azure resource.
# Deployment names live here because they are generic model identifiers —
# move them back to .env if you ever rename to something project-specific
# like "acme-prod-rag-2026".
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-5.2-chat
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large
AZURE_OPENAI_EMBEDDING_COLLECTION=podcasts_azure

# UI defaults shown in the toolbar (safe — these are just registry keys)
UI_DEFAULT_EMBED_KEY=multilingual
UI_DEFAULT_LLM_KEY=azure-openai

# Langfuse: only the public host and the on/off knob are safe here.
# The public/secret keys are credentials and must live in .env only.
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_ENABLED=true
# Flip to true to include the full system+user prompt in the
# `final-generation` span input. Off by default to keep retrieved chunk
# text out of traces; the auto SDK observation under each generation
# still carries the raw message array if you need the unredacted view.
LANGFUSE_LOG_FULL_PROMPTS=false

# LLM streaming toggle — flip to false to force non-streaming completions
# so Langfuse/OTel captures usage/token data reliably. Behaviour is
# identical from the caller's perspective; only the upstream SDK call
# shape changes.
ENABLE_LLM_STREAMING=false
