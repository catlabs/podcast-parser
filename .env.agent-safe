# .env.agent-safe
# ===============
# Companion to .env, *intended* to be readable by AI agents and indexing tools.
#
# - The application does NOT load this file. Only .env is loaded by
#   rag/config.py's load_dotenv() call.
# - Anything here must be NON-SENSITIVE: no API keys, no resource names,
#   no internal hostnames.
# - This file is committed to git; .env is not.
#
# Use this as a hint to agents about which knobs exist and what their
# typical values look like, without exposing the real credentials.

# Local providers
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# Local paths (relative to repo root)
OUTPUT_DIR=./output
DATA_DIR=./rag/data
CHROMA_DIR=./rag/data/chroma
DB_PATH=./rag/data/metadata.db

# FastAPI / Vite dev defaults
CORS_ALLOW_ORIGINS=http://localhost:5173
# VITE_API_BASE_URL=http://localhost:8000     # frontend uses this

# Azure: non-sensitive knobs ONLY. Endpoint, API key, and deployment names
# stay in .env — they identify the customer's Azure resource.
AZURE_OPENAI_API_VERSION=2024-12-01-preview
AZURE_OPENAI_EMBEDDING_COLLECTION=podcasts_azure

# UI defaults shown in the toolbar (safe — these are just registry keys)
UI_DEFAULT_EMBED_KEY=multilingual
UI_DEFAULT_LLM_KEY=azure-openai
