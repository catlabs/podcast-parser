ANTHROPIC_API_KEY=
OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=

# Application Insights / Azure Monitor — Phase 1.OBS.1
# Opt-in SECOND OTel exporter alongside Langfuse. Same TracerProvider,
# same spans, two backends (Langfuse for dev flow, App Insights for
# operator flow + KQL). Authenticates via DefaultAzureCredential — the
# InstrumentationKey embedded in the value below is used for endpoint
# discovery only, NOT for authentication. The connection string itself
# is non-sensitive (workspace identifier), so it lives in .env rather
# than a secret store, but the agent-safe file does not pin a real
# resource. Shape:
#   InstrumentationKey=<guid>;IngestionEndpoint=https://<region>.in.applicationinsights.azure.com/;LiveEndpoint=https://<region>.livediagnostics.monitor.azure.com/
APPLICATIONINSIGHTS_CONNECTION_STRING=

# Retrieval relevance threshold (Phase 1.1k) — opt-in, unset = disabled.
# Chunks whose derived cosine-similarity score (1 − distance/2) fall below
# this value are dropped after retrieval. Only SearchAgent opts in; chat RAG
# is unaffected. Calibration guide: on-topic ≈ 0.57, off-topic ≈ 0.45,
# gibberish ≈ 0.26 (measured with minilm / all-MiniLM-L6-v2).
# RETRIEVAL_MIN_SCORE=