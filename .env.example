# ── LLM provider ──────────────────────────────────────────────────────────────
# "anthropic" (default) or "ollama"
LLM_PROVIDER=anthropic

# Required when LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Used when LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3
