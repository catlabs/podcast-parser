# ── Anthropic (required for Claude models) ────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── OpenAI (required for GPT models) ─────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Ollama (required for the local Ollama option) ─────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── Local paths (optional — defaults preserve current layout) ─────────────────
# Override these when running in a container or on a different volume.
# All four are read by rag/config.py.
# OUTPUT_DIR=./output
# DATA_DIR=./rag/data
# CHROMA_DIR=./rag/data/chroma
# DB_PATH=./rag/data/metadata.db

# ── CORS (optional) ───────────────────────────────────────────────────────────
# Comma-separated list of origins allowed by the FastAPI server.
# Default: http://localhost:5173
# CORS_ALLOW_ORIGINS=http://localhost:5173

# ── Azure OpenAI (optional, opt-in) ───────────────────────────────────────────
# Chat: set AZURE_OPENAI_ENDPOINT (+ API_KEY + DEPLOYMENT) to enable the
#       "Azure · <deployment>" entry in the LLM dropdown.
# Embeddings: additionally set AZURE_OPENAI_EMBEDDING_DEPLOYMENT to register
#       a new embedding key "azure-openai" in EMBED_REGISTRY. Vectors land in
#       a separate Chroma collection (default: podcasts_azure) — local
#       collections are NOT replaced. Reindex / backfill commands documented
#       in MIGRATION.md.
#
# Shared (chat + embeddings):
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
# AZURE_OPENAI_API_KEY=
# AZURE_OPENAI_API_VERSION=2024-10-21                # default if unset
#
# Chat-only:
# AZURE_OPENAI_DEPLOYMENT=<chat-deployment-name>     # NOT the model name
#
# Embeddings-only:
# AZURE_OPENAI_EMBEDDING_DEPLOYMENT=<embed-deployment-name>
# AZURE_OPENAI_EMBEDDING_COLLECTION=podcasts_azure   # default if unset

# ── Azure placeholders (NOT USED YET — reserved for future migration steps) ──
# Leave commented. Filling these in does nothing today; they are listed here so
# the migration plan and the env contract stay in sync.
#
# Azure Blob Storage (planned replacement for local OUTPUT_DIR / DATA_DIR)
# AZURE_STORAGE_ACCOUNT=
# AZURE_STORAGE_CONTAINER=
# AZURE_STORAGE_CONNECTION_STRING=
#
# Azure AI Speech (planned replacement for local Whisper)
# AZURE_SPEECH_KEY=
# AZURE_SPEECH_REGION=
#
# Azure AI Search (planned alternative to ChromaDB)
# AZURE_SEARCH_ENDPOINT=
# AZURE_SEARCH_API_KEY=
# AZURE_SEARCH_INDEX=
