.DS_Store

# Python cache and bytecode
__pycache__/
*.py[cod]
*$py.class

# Virtual environments
.venv/
venv/
env/

# Tooling and local runtime data
# Ignore .claude/ contents (settings.local.json, skills, etc.) EXCEPT the role
# wrappers under .claude/agents/ — those are tracked so `--agent ai-mentor|
# coder|operator` survives across machines/sessions (they were local-only
# before and got lost). Must ignore contents (.claude/*), not the dir itself,
# or the negations below can't re-include.
.claude/*
!.claude/agents/
.claude/agents/*
!.claude/agents/*.md
.chroma_step0/
output/
rag/data/

# Test and coverage artifacts
.pytest_cache/
.coverage
.coverage.*
htmlcov/

# Type checkers and lint caches
.mypy_cache/
.ruff_cache/
.pyre/
.env
node_modules/
dist/

# Per-developer agent scratchpad — see .ai/README.md
.ai/memory/personal/

# Per-developer agent local context — see .ai/README.md
# Sibling .local.md files complement public agent contracts with
# personal/situational info (employer, mission, secret-adjacent context).
.ai/agents/*.local.md
